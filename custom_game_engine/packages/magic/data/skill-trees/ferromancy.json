    {
      "id": "fractured",
      "name": "Fractured",
      "description": "The breaking point that awakens Ferromancy potential",
      "paradigmId": "ferromancy",
      "category": "foundation",
      "tier": 0,
      "xpCost": 0,
      "maxLevel": 1,
      "effects": [
        {
          "type": "unlock_ability",
          "baseValue": 1,
          "description": "Can feel metal reserves",
          "target": {
            "abilityId": "metal_sense_internal"
          }
        }
      ],
      "unlockConditions": [
        {
          "type": "the_fracture",
          "params": {},
          "description": "Must experience a the_fracture event (severe trauma that awakens powers)",
          "hidden": true
        }
      ],
      "conditionMode": "all",
      "lore": "The Fracture is the moment of trauma that unlocks Ferromancy. For many, it happens\nin childhood - a moment of intense fear, pain, or grief that breaks something inside\nand lets the power through. Not all with the bloodline will Snap. Some go their\nwhole lives never knowing what they could have been.",
      "hidden": true,
      "icon": "💔"
    },
