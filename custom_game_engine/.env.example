# PixelLab API Configuration
# Get your API key from https://pixellab.ai/dashboard
PIXELLAB_API_KEY=your-api-key-here

# LLM Provider Configuration
# Keys are server-side only (no VITE_ prefix) — never bundled into client JS.
# The Vite dev server and production.ts proxy LLM calls server-side.

# Primary provider: Cerebras (fast, free tier available)
# Get your API key from https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=qwen-3-32b

# Backup provider: Groq (fast, free tier available)
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# SharedWorker Architecture (Background World Loading)
# Set to 'true' to move simulation to a SharedWorker thread:
# - Non-blocking page refresh (worker keeps running)
# - Background save loading (no main thread freeze)
# - Future: background universe simulation
# VITE_USE_SHARED_WORKER=true
